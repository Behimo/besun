APP_NAME="Rahbar CRM"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=fa
APP_FALLBACK_LOCALE=fa
APP_FAKER_LOCALE=fa_IR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=rahbar_crm
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=60
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

SANCTUM_EXPIRATION=60

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
VITE_API_BASE_URL=/api/v1
VITE_MAPBOX_ACCESS_TOKEN=

IPPANEL_BASE_URL=https://edge.ippanel.com/v1
# کلید را از پنل IPPanel > Developers > Access Keys بگیرید (فقط مقدار کلید، بدون AccessKey و بدون تکرار نام متغیر)
IPPANEL_AGENCY_API_KEY=
IPPANEL_OTP_FROM_NUMBER=+983000505
# کد پترن OTP از پنل IPPanel (باید متعلق به همین حساب و فعال باشد؛ متغیر پیش‌فرض: code)
IPPANEL_OTP_PATTERN_CODE=3cs7e2fhrq17s3w
IPPANEL_OTP_PATTERN_PARAM=code
IPPANEL_DEFAULT_ACL_ID=
IPPANEL_AUTO_APPROVE_SMS_REQUESTS=true
SMS_PLATFORM_ADMIN_IDS=1
PLATFORM_SUPER_ADMIN_EMAIL=admin@rahbar.local
PLATFORM_SUPER_ADMIN_PASSWORD=ChangeMe123!
PLATFORM_SUPER_ADMIN_NAME="مدیر کل"
SMS_BULK_BATCH_SIZE=100
SMS_CREDIT_CACHE_TTL=300

# ── OTP (کد ورود با موبایل) ─────────────────────────────────────────────
OTP_LENGTH=6
OTP_TTL_SECONDS=300
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5
# true = کد در پاسخ API (فقط توسعه). روی production حتماً false
OTP_EXPOSE_IN_RESPONSE=false

# اتصال CRM به ووکامرس — در صورت خطای SSL گواهی self-signed
WOOCOMMERCE_VERIFY_SSL=true
# در صورت مسدود شدن توسط BitNinja/Cloudflare، User-Agent سفارشی (اختیاری)
# WOOCOMMERCE_USER_AGENT="RahbarCRM/1.0 WooCommerce-API-Client"
# هدرهای اضافه JSON برای bypass هاست (اختیاری): {"X-Api-Bypass":"secret"}
# WOOCOMMERCE_HTTP_HEADERS={}
